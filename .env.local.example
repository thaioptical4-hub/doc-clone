# Vercel Postgres connection string
POSTGRES_URL="postgres://..."

# NextAuth.js secret (generate: openssl rand -base64 32)
NEXTAUTH_SECRET="change-me"

# Single admin credentials for the auth gate
APP_USER="admin"
APP_PASS="change-me"

# Google Drive backup (auto-uploads a PDF on every confirmed receipt)
# See scripts/get-google-refresh-token.mjs for how to obtain these.
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="change-me"
GOOGLE_REFRESH_TOKEN="change-me"
# Optional: Drive folder ID to upload into (defaults to My Drive root)
GOOGLE_DRIVE_FOLDER_ID=""
